{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "foundercrm",
  "main": "src/worker.ts",
  "compatibility_date": "2026-04-14",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "OAUTH_TOKENS",
      "id": "18c7652209314dd08177754a0d8e4d24"
    }
  ]
}
